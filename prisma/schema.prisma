generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model contract {
  id                               String   @id
  title                            String
  description                      String   @db.Text
  milestoneAmount                  Float
  totalAmount                      Float
  deadline                         DateTime
  status                           String   @default("PENDING_ACCEPTANCE")
  outcome                          String?
  fundedAt                         DateTime?
  acceptedAt                       DateTime?
  completedAt                      DateTime?
  disputedAt                       DateTime?
  outcomeReportedBy                String?
  outcomeNote                      String?  @db.Text
  employerId                       String
  freelancerId                     String?
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime
  web3JobId                        String?  @unique(map: "Contract_web3JobId_key")
  user_contract_employerIdTouser   user     @relation("contract_employerIdTouser", fields: [employerId], references: [id], map: "Contract_employerId_fkey")
  user_contract_freelancerIdTouser user?    @relation("contract_freelancerIdTouser", fields: [freelancerId], references: [id], map: "Contract_freelancerId_fkey")

  @@index([employerId], map: "Contract_employerId_fkey")
  @@index([freelancerId], map: "Contract_freelancerId_fkey")
}

model profile {
  id             String  @id
  userId         String  @unique(map: "Profile_userId_key")
  handle         String? @unique(map: "Profile_handle_key")
  displayName    String?
  bio            String? @db.Text
  role           String  @default("BOTH")
  privacyMode    String  @default("SELECTIVE")
  isFreelancer   Boolean @default(false)
  githubVerified Boolean @default(false)
  upworkVerified Boolean @default(false)
  user           user    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Profile_userId_fkey")
}

model user {
  id                                   String     @id
  walletAddress                        String     @unique(map: "User_walletAddress_key")
  createdAt                            DateTime   @default(now())
  updatedAt                            DateTime
  contract_contract_employerIdTouser   contract[] @relation("contract_employerIdTouser")
  contract_contract_freelancerIdTouser contract[] @relation("contract_freelancerIdTouser")
  profile                              profile?
}
